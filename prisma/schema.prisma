generator client {
  provider = "prisma-client-js"
  // Klient używa WASM query compiler (@prisma/adapter-pg) — działa na serverless
  // bez natywnych binariów, więc binaryTargets nie są potrzebne.
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  email    String @unique
  password String
  name     String
  role     Role   @default(AGENT)

  @@map("users")
}

enum Role {
  ADMIN
  AGENT
}

model Listing {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title    String
  slug     String          @unique
  category ListingCategory
  status   ListingStatus   @default(ACTIVE)

  // Numer oferty ze źródła / systemu pośrednika (np. import z lw.nieruchomosci.pl)
  referenceNumber String?

  transactionType TransactionType @default(SPRZEDAZ)
  market          Market?

  // Flagi publikacji
  isFeatured    Boolean @default(false) // Polecana — sekcja "Polecane" na stronie głównej
  isHighlighted Boolean @default(false) // Wyróżniona — ramka/etykieta na liście
  isExclusive   Boolean @default(false) // Na wyłączność
  isDeal        Boolean @default(false) // Okazja

  // Parametry
  price       Float
  oldPrice    Float?
  area        Float?
  rooms       Int?
  floor       Int?
  totalFloors Int?
  yearBuilt   Int?
  condition   Condition?
  heating     Heating?

  // Lokalizacja
  voivodeship String? @default("Dolnośląskie")
  city        String
  district    String?
  postalCode  String?
  lat         Float?
  lng         Float?

  amenities   String[] @default([])
  description String   @db.Text

  images    ListingImage[]
  inquiries Inquiry[]

  @@map("listings")
}

model ListingImage {
  id        Int     @id @default(autoincrement())
  url       String
  order     Int     @default(0)
  isMain    Boolean @default(false)
  listingId Int
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("listing_images")
}

enum ListingCategory {
  MIESZKANIE
  DOM
  DZIALKA
  LOKAL
}

enum ListingStatus {
  ACTIVE
  DRAFT
  RESERVED
  SOLD
}

enum TransactionType {
  SPRZEDAZ
  WYNAJEM
  DZIERZAWA
}

enum Market {
  WTORNY
  PIERWOTNY
}

enum Condition {
  DO_ZAMIESZKANIA
  DO_ODSWIEZENIA
  DO_REMONTU
  DEWELOPERSKI
  SUROWY_ZAMKNIETY
}

enum Heating {
  MIEJSKIE
  GAZOWE
  POMPA_CIEPLA
  ELEKTRYCZNE
  KOMINKOWE
}

model Article {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slug     String        @unique
  status   ArticleStatus @default(DRAFT)
  featured Boolean       @default(false) // wyróżniony (duża karta na górze bloga)

  // Karta / nagłówek
  category      String // "Rynek", "Porady", "Sprzedaż", "Kupno", "Kredyty"
  title         String
  titleEmphasis String? // słowo/fraza z tytułu wyróżniona na złoto w H1
  excerpt       String  @db.Text // zajawka na karcie listy
  lead          String? @db.Text // wprowadzenie pod H1 na stronie artykułu
  readTime      String? // np. "8 min czytania"
  publishedAt   DateTime? // data publikacji (wyświetlana + sortowanie)

  // Zdjęcie główne (też miniatura karty + og:image)
  coverImage   String
  coverAlt     String?
  coverCaption String?

  // Treść — tablica bloków (sekcja / akapit / cytat / lista / zdjecie / statystyki)
  content Json     @default("[]")
  tags    String[] @default([])

  // Autor (denormalizowany — małe biuro)
  authorName     String  @default("Zespół LW Nieruchomości")
  authorRole     String?
  authorInitials String?
  authorBio      String? @db.Text

  // SEO
  seoTitle       String?
  seoDescription String? @db.Text
  ogImage        String?

  @@map("articles")
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
}

model Inquiry {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  type    InquiryType
  status  InquiryStatus @default(NEW)
  subject String? // skąd/temat, np. "Wycena nieruchomości", "Lokalizacja: Karpacz"
  name    String
  message String        @db.Text
  contact String

  listingId Int?
  listing   Listing? @relation(fields: [listingId], references: [id])

  @@map("inquiries")
}

enum InquiryType {
  OFFER
  SEARCH
  CONTACT
  SERVICE
  NEWSLETTER
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  DONE
}
