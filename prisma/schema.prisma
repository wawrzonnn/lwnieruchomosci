generator client {
  provider      = "prisma-client-js"
  // "native" — lokalnie; "rhel-openssl-3.0.x" — runtime funkcji Netlify (AWS Lambda / Node 20+).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  email    String @unique
  password String
  name     String
  role     Role   @default(AGENT)

  @@map("users")
}

enum Role {
  ADMIN
  AGENT
}

model Listing {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title    String
  slug     String          @unique
  category ListingCategory
  status   ListingStatus   @default(ACTIVE)

  transactionType TransactionType @default(SPRZEDAZ)
  market          Market?

  // Flagi publikacji
  isFeatured    Boolean @default(false) // Polecana — sekcja "Polecane" na stronie głównej
  isHighlighted Boolean @default(false) // Wyróżniona — ramka/etykieta na liście
  isExclusive   Boolean @default(false) // Na wyłączność
  isDeal        Boolean @default(false) // Okazja

  // Parametry
  price       Float
  oldPrice    Float?
  area        Float?
  rooms       Int?
  floor       Int?
  totalFloors Int?
  yearBuilt   Int?
  condition   Condition?
  heating     Heating?

  // Lokalizacja
  voivodeship String? @default("Dolnośląskie")
  city        String
  district    String?
  postalCode  String?
  lat         Float?
  lng         Float?

  amenities   String[] @default([])
  description String   @db.Text

  images    ListingImage[]
  inquiries Inquiry[]

  @@map("listings")
}

model ListingImage {
  id        Int     @id @default(autoincrement())
  url       String
  order     Int     @default(0)
  isMain    Boolean @default(false)
  listingId Int
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("listing_images")
}

enum ListingCategory {
  MIESZKANIE
  DOM
  DZIALKA
  LOKAL
}

enum ListingStatus {
  ACTIVE
  DRAFT
  RESERVED
  SOLD
}

enum TransactionType {
  SPRZEDAZ
  WYNAJEM
  DZIERZAWA
}

enum Market {
  WTORNY
  PIERWOTNY
}

enum Condition {
  DO_ZAMIESZKANIA
  DO_ODSWIEZENIA
  DO_REMONTU
  DEWELOPERSKI
  SUROWY_ZAMKNIETY
}

enum Heating {
  MIEJSKIE
  GAZOWE
  POMPA_CIEPLA
  ELEKTRYCZNE
  KOMINKOWE
}

model Inquiry {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  type    InquiryType
  status  InquiryStatus @default(NEW)
  name    String
  message String        @db.Text
  contact String

  listingId Int?
  listing   Listing? @relation(fields: [listingId], references: [id])

  @@map("inquiries")
}

enum InquiryType {
  OFFER
  SEARCH
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  DONE
}
